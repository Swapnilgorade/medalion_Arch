# 🔷 FUNCTION TO CREATE TICKET
def create_jira_ticket(summary, description, issue_type="Bug", priority=None):

    headers = {
        "Accept": "application/json",
        "Content-Type": "application/json"
    }

    # 🔷 Base payload
    payload = {
        "fields": {
            "project": {
                "key": PROJECT_KEY
            },
            "summary": summary,
            "description": description,
            "issuetype": {
                "name": issue_type
            }
        }
    }

    # 🔷 Optional: Add priority if needed
    if priority:
        payload["fields"]["priority"] = {"name": priority}

    try:
        response = requests.post(
            JIRA_URL,
            headers=headers,
            json=payload,   # ✅ important
            auth=(EMAIL, API_TOKEN)
        )

        print("Status Code:", response.status_code)

        if response.status_code == 201:
            data = response.json()
            print("✅ Ticket Created Successfully")
            print("Ticket ID:", data.get("id"))
            print("Ticket Key:", data.get("key"))
            print("URL:", data.get("self"))
            return data

        else:
            print("❌ Failed to create ticket")
            print("Response:", response.text)
            return None

    except Exception as e:
        print("❌ Exception occurred:", str(e))
        return None


